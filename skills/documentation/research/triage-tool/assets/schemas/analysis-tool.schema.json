{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "analysis-tool",
  "description": "Frontmatter schema for ANALYSIS-<slug>.md files in the research repo",
  "type": "object",
  "required": [
    "slug",
    "title",
    "date",
    "type",
    "tool",
    "source",
    "local_clone",
    "reviewed",
    "reviewed_date",
    "source_reviewed",
    "updated"
  ],
  "additionalProperties": true,
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier matching the filename stem after ANALYSIS-; always author-or-org-tool-name"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "type": {
      "type": "string",
      "const": "analysis"
    },
    "tool": {
      "type": "object",
      "required": ["name", "repo"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "pattern": "^https?://"
        },
        "version": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      }
    },
    "source": {
      "type": "string",
      "pattern": "^https?://",
      "description": "GitHub URL of the tool repository (string, not array)"
    },
    "local_clone": {
      "type": "string",
      "description": "Relative path to the vendored submodule, e.g. ../tools/{slug}"
    },
    "reviewed": {
      "type": "boolean"
    },
    "reviewed_date": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_reviewed": {
      "type": "boolean",
      "description": "True only if source code was read directly (not just README/docs)"
    },
    "updated": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "links": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
