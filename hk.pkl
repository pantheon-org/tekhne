amends "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.49.0/hk@1.49.0#/Builtins.pkl"

// Migrated from lefthook.yml. Custom steps mirror the exact commands the
// project used so behaviour is preserved. `check` runs a non-mutating
// verification (used by `hk check` and CI); `fix` runs the mutating variant
// (used by the pre-commit hook, which stages the results automatically).

// -- pre-commit linters (run in parallel on staged files) --
local preCommit = new Mapping<String, Step> {
    ["biome"] {
        glob = List("*.js", "*.cjs", "*.mjs", "*.ts", "*.tsx", "*.jsx", "*.json", "*.jsonc")
        // Golden-corpus test data (Go-generated goldens + copied fixtures) is
        // reference data, not source; do not reformat it.
        exclude = List(
            "crates/skill-validator-rs/tests/golden-corpus/**",
            "crates/skill-auditor/tests/golden-corpus/**"
        )
        check = "bunx @biomejs/biome check --no-errors-on-unmatched {{files}}"
        fix = "bunx @biomejs/biome check --write --no-errors-on-unmatched {{files}}"
    }
    ["markdownlint"] {
        glob = List("*.md")
        exclude = List(".context/**", "docs/src/content/docs/tiles.md", "crates/skill-validator-rs/tests/golden-corpus/fixtures/**")
        check = "markdownlint-cli2 --config .markdownlint-cli2.jsonc {{files}}"
        fix = "markdownlint-cli2 --fix --config .markdownlint-cli2.jsonc {{files}}"
    }
    // Validation only (no file mutation); runs on every commit like the
    // original glob-less lefthook command. Ported from the shell
    // validate-skill-artifacts.sh into `skill-validator-rs validate artifacts`
    // (Wave 2). Builds the Rust validator once (cached in target/release) then
    // invokes it; exit 1 = error (blocking), exit 0 = clean.
    ["skill-artifacts"] {
        // Scoped to skill files so the step only runs (per-file) when a skill
        // changes. Without a glob, a commit touching no skill files passes an
        // empty {{files}}, which `validate artifacts` treats as a whole-tree
        // scan and then blocks the commit on unrelated pre-existing findings.
        glob = List("skills/**")
        shell = "sh -c"
        check = #"""
if [ ! -x target/release/skill-validator-rs ]; then
  cargo build --release -q -p skill-validator-rs || { echo "skill-validator-rs build failed; skipping local validation (CI enforces the gate)"; exit 0; }
fi
target/release/skill-validator-rs validate artifacts {{files}}
"""#
    }
    // Guardrail: no .py may live outside a directory listed in
    // python-allowlist.txt. Python is retained only for the allowlisted skills,
    // so a stray .py is a mis-placed script or an allowlist gap. Glob-less so it
    // scans the whole tree on every commit; offline and deterministic.
    ["python-allowlist"] {
        check = "./scripts/check-python-allowlist.sh"
    }
    // Regenerates README.md + docs tiles from skills and audit data, staging
    // them. Fix-only: `--dry-run` exits 0 even when out of sync, which would
    // let hk's check-first skip the regeneration, so there is no `check`
    // variant (matches lefthook, which always regenerated). Skipped by
    // `hk check`; use `bun run readme:update:dry-run` for a CI drift check.
    ["readme-sync"] {
        glob = List("skills/**", ".context/audits/**")
        fix = "bun scripts/catalog/update.ts && markdownlint-cli2 --config .markdownlint-cli2.jsonc README.md"
        stage = List("README.md", "docs/src/content/docs/tiles.md")
    }
    ["yamllint"] {
        glob = List("*.yml", "*.yaml")
        exclude = List("crates/skill-validator-rs/tests/golden-corpus/fixtures/**")
        shell = "sh -c"
        check = "command -v yq >/dev/null 2>&1 && yq eval '.' {{files}} >/dev/null"
    }
    ["shellcheck"] {
        glob = List("*.sh")
        exclude = List("crates/skill-validator-rs/tests/golden-corpus/fixtures/**")
        shell = "sh -c"
        check = "command -v shellcheck >/dev/null 2>&1 && shellcheck {{files}}"
    }
    ["tessl-lint"] {
        glob = List("skills/**/SKILL.md")
        shell = "sh -c"
        check = #"for f in {{files}}; do dir=$(dirname "$f"); if [ -f "$dir/tile.json" ]; then bun run tessl:lint -- "$f" || exit 1; fi; done"#
    }
    // Builds the Rust validator from source once (cached in target/release),
    // then invokes it. Exit-code contract preserved: exit 1 = error (blocking,
    // rc=1); exit 2 = warning (non-blocking); exit 0 = clean.
    ["skill-validate"] {
        glob = List("skills/**/SKILL.md")
        shell = "sh -c"
        check = #"""
if [ ! -x target/release/skill-validator-rs ]; then
  cargo build --release -q -p skill-validator-rs || { echo "skill-validator-rs build failed; skipping local validation (CI enforces the gate)"; exit 0; }
fi
rc=0
for f in {{files}}; do
  target/release/skill-validator-rs validate structure --allow-dirs=evals "$(dirname "$f")"
  [ $? -eq 1 ] && rc=1
done
exit $rc
"""#
    }
}

// -- pre-push checks (tests + skill quality gates) --
local prePush = new Mapping<String, Step> {
    ["unit-tests"] {
        check = "bun test scripts/"
    }
    ["integration-tests"] {
        check = "bunx cucumber-js"
    }
    // Builds the Rust validator from source once (cached in target/release),
    // then invokes it. Exit 1 = error (blocking, rc=1); exit 2 = warning
    // (non-blocking); exit 0 = clean.
    ["skill-check"] {
        glob = List("skills/**/SKILL.md")
        shell = "sh -c"
        check = #"""
if [ ! -x target/release/skill-validator-rs ]; then
  cargo build --release -q -p skill-validator-rs || { echo "skill-validator-rs build failed; skipping local validation (CI enforces the gate)"; exit 0; }
fi
rc=0
for f in {{files}}; do
  target/release/skill-validator-rs check --allow-dirs=evals --per-file "$(dirname "$f")"
  [ $? -eq 1 ] && rc=1
done
exit $rc
"""#
    }
    // Builds the Rust auditor from source once (cached in target/release),
    // then invokes it. Grade gate preserved: A/A+ pass; B+/B/C+/C warn
    // (non-blocking); below C fail (rc=1).
    ["skill-audit"] {
        glob = List("skills/**/SKILL.md")
        shell = "sh -c"
        check = #"""
if [ ! -x target/release/skill-auditor ]; then
  cargo build --release -q -p skill-auditor || { echo "skill-auditor build failed; skipping local audit (CI enforces the gate)"; exit 0; }
fi
rc=0
for f in {{files}}; do
  rel="$(dirname "$f")"; rel="${rel#skills/}"
  grade=$(target/release/skill-auditor evaluate "$rel" --json 2>/dev/null | jq -r '.grade // "?"' 2>/dev/null)
  case "$grade" in
    A|A+) echo "PASS $rel: $grade";;
    B+|B|C+|C) echo "WARN $rel: $grade (warning -- CI non-blocking)";;
    *) echo "FAIL $rel: ${grade:-?} (below C -- blocked)"; rc=1;;
  esac
done
exit $rc
"""#
    }
}

hooks {
    ["pre-commit"] {
        fix = true       // apply fix steps and stage the results
        stash = "git"    // stash unstaged changes so only staged content is linted
        steps = preCommit
    }
    ["pre-push"] {
        steps = prePush
    }
    // Special hooks powering `hk fix` and `hk check` (handy in CI).
    ["fix"] {
        fix = true
        steps = preCommit
    }
    ["check"] {
        steps = preCommit
    }
}
