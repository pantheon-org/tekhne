{
  "name": "tekhne",
  "version": "1.0.0",
  "description": "A curated collection of reusable agent skills for AI assistants, designed for easy redistribution and integration.",
  "main": "index.js",
  "scripts": {
    "docs:build": "cd docs && bun run build",
    "docs:dev": "cd docs && bun run dev",
    "prepare": "hk install",
    "check:biome": "bunx @biomejs/biome check .",
    "check:markdown": "markdownlint-cli2 \"**/*.md\"",
    "check:skill-artifacts": "./skills/agentic-harness/skill-quality-auditor/scripts/validate-skill-artifacts.sh",
    "audit:skill": "cargo build --release -q -p skill-auditor && target/release/skill-auditor evaluate",
    "readme:update": "bun scripts/catalog/update.ts",
    "readme:update:dry-run": "bun scripts/catalog/update.ts --dry-run",
    "tessl:import": "tessl skill import",
    "tessl:lint": "tessl plugin lint",
    "tessl:publish": "tessl plugin publish",
    "tessl:review": "tessl review run",
    "test": "bun test scripts/",
    "test:integration": "cucumber-js",
    "build:skill-auditor": "cargo build --release -p skill-auditor"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@cucumber/cucumber": "^13.0.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "tessl": "^0.90.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "badge-maker": "^6.0.0",
    "ajv": "^8.18.0",
    "js-yaml": "^5.2.1",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.3.6"
  }
}
