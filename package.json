{
  "name": "tekhne",
  "version": "1.0.0",
  "description": "A curated collection of reusable agent skills for AI assistants, designed for easy redistribution and integration.",
  "main": "index.js",
  "bin": {
    "tekhne": "./cli/index.ts"
  },
  "scripts": {
    "docs:build": "cd docs && bun run build",
    "docs:dev": "cd docs && bun run dev",
    "prepare": "bunx lefthook install",
    "check:biome": "bunx @biomejs/biome check .",
    "check:markdown": "bunx markdownlint-cli2 \"**/*.md\"",
    "check:skill-artifacts": "./skills/agentic-harness/skill-quality-auditor/scripts/validate-skill-artifacts.sh",
    "audit:skill": "bun cli/index.ts audit skill",
    "audit:skills": "bun cli/index.ts audit all",
    "audit:skills:force": "bun cli/index.ts audit all --force",
    "audit:status": "bun cli/index.ts audit status",
    "audit:summary": "bun cli/index.ts audit summary",
    "readme:update": "bun cli/index.ts readme update",
    "readme:update:dry-run": "bun cli/index.ts readme update --dry-run",
    "sync:opencode": "bun cli/index.ts sync opencode",
    "sync:opencode:dry-run": "bun cli/index.ts sync opencode --dry-run",
    "tessl:manage": "bun cli/index.ts tessl manage",
    "tessl:publish-check": "bun cli/index.ts tessl publish-check",
    "tessl:import": "tessl skill import",
    "tessl:lint": "tessl skill lint",
    "tessl:publish": "tessl skill publish",
    "tessl:review": "tessl skill review",
    "test": "bun test",
    "test:integration": "cucumber-js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@cucumber/cucumber": "^11.0.0",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "lefthook": "^2.1.1",
    "markdownlint-cli2": "^0.21.0",
    "tessl": "^0.68.0",
    "tsx": "^4.0.0"
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command",
    "@cliffy/prompt": "npm:@jsr/cliffy__prompt",
    "badge-maker": "^5.0.2",
    "js-yaml": "^4.1.1",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.3.6"
  }
}
