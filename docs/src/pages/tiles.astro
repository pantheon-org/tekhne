---
import { getCollection } from "astro:content";
import SkillCard from "../components/SkillCard.astro";
import DocsLayout from "../layouts/DocsLayout.astro";
import { buildSkillToTileMap, loadPublicTiles } from "../lib/tiles";

const allDocs = await getCollection("docs");
const skillEntries = allDocs.filter((e) => {
  const id = e.id as string;
  return id.endsWith("/skill") || id.endsWith("/SKILL.mdx");
});

const base = import.meta.env.BASE_URL;
const publicTiles = loadPublicTiles();
const _skillToTile = buildSkillToTileMap();

interface TileCardData {
  tileSlug: string;
  tileName: string;
  tileHref: string;
  skillCount: number;
  version: string;
  skills: Array<{
    href: string;
    title: string;
    description: string | undefined;
    grade: string | undefined;
    domain: string;
    evalCount: number | undefined;
    auditDate: string | undefined;
  }>;
}

const tileCards: TileCardData[] = publicTiles
  .map((tile) => {
    const skills = Object.keys(tile.skills)
      .map((key) => {
        const entry = skillEntries.find((e) => {
          const d = e.data as Record<string, unknown>;
          return d.name === key;
        });
        if (!entry) return null;
        const data = entry.data as Record<string, unknown>;
        const metadata = (data.metadata as Record<string, unknown>) ?? {};
        const skillAudit = data.skillAudit as
          | Record<string, unknown>
          | undefined;
        const skillAudits = data.skillAudits as
          | Array<Record<string, unknown>>
          | undefined;
        const skillEvals = data.skillEvals as unknown[] | undefined;
        const grade =
          (skillAudit?.grade as string | undefined) ??
          (metadata.grade as string | undefined);
        const auditDate =
          ((skillAudit?.date ?? skillAudit?.auditDate) as string | undefined) ??
          ((skillAudits?.[0]?.date ?? skillAudits?.[0]?.auditDate) as
            | string
            | undefined);
        const evalCount = skillEvals?.length;
        const parts = entry.id.split("/");
        const skillsIdx = parts.indexOf("skills");
        const domain =
          skillsIdx >= 0 ? (parts[skillsIdx + 1] ?? "unknown") : "unknown";
        const skillPath =
          skillsIdx >= 0 ? parts.slice(skillsIdx + 1).join("/") : entry.id;
        const href = `${base}/skills/${skillPath.replace(/\/skill$/, "/skill/")}/`;
        const meta = (data.metadata as Record<string, unknown>) ?? {};
        const title =
          (meta.displayTitle as string | undefined) ??
          (data.name as string | undefined) ??
          entry.data.title;
        return {
          href,
          title,
          description: data.description as string | undefined,
          grade,
          domain,
          evalCount,
          auditDate,
        };
      })
      .filter(Boolean) as TileCardData["skills"];

    const tileLabelRaw = tile.name.replace(/^[^/]+\//, "");
    const tileName = tileLabelRaw.replace(/-/g, " ");

    return {
      tileSlug: tile.slug,
      tileName,
      tileHref: `${base}/tiles/${tile.slug}/`,
      skillCount: skills.length,
      version: tile.version,
      skills,
    };
  })
  .filter((t) => t.skills.length > 0);

tileCards.sort((a, b) => a.tileName.localeCompare(b.tileName));
---

<DocsLayout title="Tile Catalog" description="All Tekhne tiles and skills organized by tile.">
  <h1>Tile Catalog</h1>
  <p class="subtitle">{tileCards.length} tiles available</p>

  {tileCards.map((tile) => (
    <section class="tile-section">
      <h2>
        <a href={tile.tileHref} class="tile-heading-link">{tile.tileName}</a>
        <span class="tile-meta">
          <span class="tile-version">v{tile.version}</span>
          <span class="tile-count">{tile.skillCount} skill{tile.skillCount !== 1 ? "s" : ""}</span>
        </span>
      </h2>
      <div class="skill-cards">
        {tile.skills.map((card) => (
          <SkillCard
            href={card.href}
            title={card.title}
            description={card.description}
            domain={card.domain}
            grade={card.grade}
            evalCount={card.evalCount}
            auditDate={card.auditDate}
          />
        ))}
      </div>
    </section>
  ))}
</DocsLayout>

<style>
  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--tk-color-white);
  }

  .subtitle {
    color: var(--tk-text-muted);
    margin-bottom: 2rem;
  }

  .tile-section {
    margin-bottom: 2.5rem;
  }

  .tile-section h2 {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--tk-border);
  }

  .tile-heading-link {
    color: var(--tk-color-white);
    text-decoration: none;
    text-transform: capitalize;
  }

  .tile-heading-link:hover {
    color: var(--tk-accent);
    text-decoration: underline;
  }

  .tile-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
  }

  .tile-version {
    font-size: 0.7rem;
    font-family: var(--tk-font-mono);
    background: var(--tk-color-accent-low);
    color: var(--tk-color-accent-high);
    border-radius: 0.375rem;
    padding: 0.2em 0.5em;
    font-weight: 500;
  }

  .tile-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5em;
    background: var(--tk-color-gray-5);
    color: var(--tk-color-gray-2);
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.1em 0.5em;
  }

  .skill-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }
</style>
