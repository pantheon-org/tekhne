---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found">
  <main class="flex flex-col items-center justify-center min-h-[60vh] gap-4 text-center p-8">
    <h1 class="text-tk-white">404 — Page Not Found</h1>
    <p class="text-tk-muted">The page you requested doesn't exist.</p>
    <a href="/tekhne/" class="text-tk-link hover:text-tk-link-hover">Go to the documentation home</a>
  </main>
</BaseLayout>
