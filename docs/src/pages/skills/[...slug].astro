---
import { getCollection, render } from "astro:content";
import SkillLayout from "../../layouts/SkillLayout.astro";
import DocsLayout from "../../layouts/DocsLayout.astro";
import SkillTabs from "../../components/SkillTabs.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");
  return entries
    .filter((entry) => entry.id.startsWith("skills/"))
    .map((entry) => {
      const slug = entry.id.replace(/^skills\//, "").replace(/\.(md|mdx)$/, "");
      return {
        params: { slug },
        props: { entry },
      };
    });
}

const { entry } = Astro.props;
const isSkillPage = entry.id.endsWith("/skill");
const { Content } = await render(entry);

const editBase = "https://github.com/pantheon-org/tekhne/edit/main/docs/";
const editUrl = `${editBase}src/content/docs/${entry.id}`;

const base = import.meta.env.BASE_URL;
const parts = entry.id.replace(/^skills\//, "").split("/");
const breadcrumbs = !isSkillPage && parts.length > 2
  ? [
      { label: "Skills", href: `${base}/skills/` },
      {
        label: parts.slice(0, -2).join(" / "),
        href: `${base}/skills/${parts.slice(0, -1).join("/").replace(/\/[^/]+$/, "/skill/")}`,
      },
      { label: entry.data.title },
    ]
  : undefined;
---

{isSkillPage ? (
  <SkillLayout entry={entry}>
    <SkillTabs entry={entry}>
      <Content />
    </SkillTabs>
    <div class="edit-link">
      <a href={editUrl} target="_blank" rel="noopener noreferrer">Edit this page on GitHub</a>
    </div>
  </SkillLayout>
) : (
  <DocsLayout title={entry.data.title} description={entry.data.description}>
    {breadcrumbs && <Breadcrumb crumbs={breadcrumbs} />}
    <article class="tk-markdown-content" data-pagefind-body data-pagefind-filter="type:reference">
      <Content />
    </article>
    <div class="edit-link">
      <a href={editUrl} target="_blank" rel="noopener noreferrer">Edit this page on GitHub</a>
    </div>
  </DocsLayout>
)}

<style>
  .edit-link {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--tk-border);
  }

  .edit-link a {
    font-size: 0.8rem;
    color: var(--tk-text-muted);
  }

  .edit-link a:hover {
    color: var(--tk-link);
  }


</style>
