---
import BaseLayout from "./BaseLayout.astro";
import LeftNav from "../components/LeftNav.astro";
import PageHeader from "../components/PageHeader.astro";

interface Props {
  title: string;
  description?: string;
  sidebar?: boolean;
}

const { title, description, sidebar = true } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <PageHeader slot="header" navToggle={sidebar} />
  <div
    class:list={[
      "grid min-h-[calc(100vh-3.5rem)]",
      sidebar
        ? "grid-cols-[16rem_1fr] max-md:grid-cols-1"
        : "grid-cols-1",
    ]}
  >
    {sidebar && <LeftNav />}
    <main class:list={[sidebar ? "p-8 overflow-auto" : "overflow-visible"]}>
      <slot />
    </main>
  </div>
</BaseLayout>
