---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import LeftNav from "../components/LeftNav.astro";
import PageHeader from "../components/PageHeader.astro";
import SkillPageTitle from "../components/SkillPageTitle.astro";
import SkillSidebar from "../components/SkillSidebar.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  entry: CollectionEntry<"docs">;
  breadcrumbs?: Crumb[];
}

const { entry, breadcrumbs } = Astro.props;
---

<BaseLayout title={entry.data.title}>
  <PageHeader slot="header" />
  <div class="grid grid-cols-[16rem_1fr_14rem] min-h-[calc(100vh-3.5rem)] max-lg:grid-cols-[16rem_1fr] max-md:grid-cols-1">
    <LeftNav />
    <main class="p-8 overflow-auto" data-pagefind-body data-pagefind-filter="type:skill">
      {breadcrumbs && breadcrumbs.length > 1 && <Breadcrumb crumbs={breadcrumbs} />}
      <SkillPageTitle entry={entry} />
      <slot />
    </main>
    <aside class="border-l border-tk-border px-4 py-6 overflow-auto max-lg:hidden">
      <SkillSidebar entry={entry} />
    </aside>
  </div>
</BaseLayout>
