---
import type { CollectionEntry } from "astro:content";
import type { TileData } from "../lib/tiles";
import BaseLayout from "./BaseLayout.astro";
import LeftNav from "../components/LeftNav.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import NavToggle from "../components/NavToggle.astro";
import SearchBar from "../components/SearchBar.astro";
import TileSidebar from "../components/TileSidebar.astro";

interface Props {
  tile: TileData;
  skillEntries: CollectionEntry<"docs">[];
}

const { tile, skillEntries } = Astro.props;
---

<BaseLayout title={tile.name} description={tile.summary}>
  <header slot="header">
    <NavToggle />
    <a href={`${import.meta.env.BASE_URL}/`} class="site-logo">Tekhne</a>
    <SearchBar />
    <ThemeToggle />
  </header>
  <div class="layout">
    <LeftNav />
    <main>
      <slot />
    </main>
    <aside class="right-sidebar">
      <TileSidebar tile={tile} skillEntries={skillEntries} />
    </aside>
  </div>
</BaseLayout>

<style>
  header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--tk-border);
    background: var(--tk-bg-surface);
  }

  .layout {
    display: grid;
    grid-template-columns: 16rem 1fr 14rem;
    min-height: calc(100vh - 3.5rem);
  }

  main {
    padding: 2rem;
    overflow: auto;
  }

  .right-sidebar {
    border-left: 1px solid var(--tk-border);
    padding: 1.5rem 1rem;
    overflow: auto;
  }

  @media (max-width: 1024px) {
    .layout {
      grid-template-columns: 16rem 1fr;
    }
    .right-sidebar {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }
</style>
