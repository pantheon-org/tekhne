---
import type { TileData } from "../lib/tiles";
import BaseLayout from "./BaseLayout.astro";
import LeftNav from "../components/LeftNav.astro";
import PageHeader from "../components/PageHeader.astro";

interface Props {
  tile: TileData;
}

const { tile } = Astro.props;
---

<BaseLayout title={tile.name} description={tile.summary}>
  <PageHeader slot="header" />
  <div class="grid grid-cols-[16rem_1fr] min-h-[calc(100vh-3.5rem)] max-md:grid-cols-1">
    <LeftNav />
    <main class="p-8 overflow-auto">
      <slot />
    </main>
  </div>
</BaseLayout>
