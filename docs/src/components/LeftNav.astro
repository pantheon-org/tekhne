---
import { getCollection } from "astro:content";
import { buildSkillToTileMap, loadPublicTiles } from "../lib/tiles";

const entries = await getCollection("docs");
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const skillToTile = buildSkillToTileMap();
const publicTiles = loadPublicTiles();

interface NavItem {
  label: string;
  href: string;
  active: boolean;
}

interface NavGroup {
  tileSlug: string;
  tileLabel: string;
  tileLandingHref: string;
  items: NavItem[];
}

const groupMap = new Map<string, NavItem[]>();

for (const entry of entries) {
  if (!entry.id.endsWith("/skill") && !entry.id.endsWith("/SKILL.mdx"))
    continue;
  const data = entry.data as Record<string, unknown>;
  const skillName = data.name as string | undefined;
  if (!skillName) continue;

  const tile = skillToTile.get(skillName);
  if (!tile) continue;

  const parts = entry.id.split("/");
  const skillsIdx = parts.indexOf("skills");
  const skillPath =
    skillsIdx >= 0 ? parts.slice(skillsIdx + 1).join("/") : entry.id;
  const href = `${base}/skills/${skillPath.replace(/\/skill$/, "/skill/")}/`;
  const active =
    currentPath === href ||
    currentPath.startsWith(`${href.replace(/\/$/, "")}/`);

  const meta = (data.metadata as Record<string, unknown>) ?? {};
  const label =
    (meta.displayTitle as string | undefined) ??
    (data.name as string | undefined) ??
    entry.data.title;

  if (!groupMap.has(tile.slug)) groupMap.set(tile.slug, []);
  groupMap.get(tile.slug)?.push({ label, href, active });
}

const groups: NavGroup[] = [];
for (const tile of publicTiles) {
  const items = groupMap.get(tile.slug);
  if (!items || items.length === 0) continue;
  items.sort((a, b) => a.label.localeCompare(b.label));
  const tileLabel = tile.name.replace(/^[^/]+\//, "").replace(/-/g, " ");
  groups.push({
    tileSlug: tile.slug,
    tileLabel,
    tileLandingHref: `${base}/tiles/${tile.slug}/`,
    items,
  });
}
groups.sort((a, b) => a.tileLabel.localeCompare(b.tileLabel));
---

<nav id="left-nav" aria-label="Skill navigation">
  {groups.map((group) => {
    const hasActive = group.items.some((i) => i.active);
    return (
      <details
        data-domain={group.tileSlug}
        open={hasActive || undefined}
      >
        <summary
          data-nav-group={group.tileSlug}
          tabindex="0"
        >
          <a
            href={group.tileLandingHref}
            class:list={["tile-link", hasActive && "tile-link--active"]}
            onclick="event.stopPropagation()"
          >
            {group.tileLabel}
          </a>
        </summary>
        <ul data-nav-group-content={group.tileSlug}>
          {group.items.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={item.active ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </details>
    );
  })}
</nav>

<script>
  const allDetails = () => document.querySelectorAll<HTMLDetailsElement>("details[data-domain]");

  const collapseOthers = (except: HTMLDetailsElement) => {
    allDetails().forEach((el) => {
      if (el !== except) el.open = false;
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    allDetails().forEach((el) => {
      const hasActive = el.querySelector("[aria-current='page']");
      if (!hasActive) el.open = false;
    });
  });

  allDetails().forEach((el) => {
    el.addEventListener("toggle", () => {
      if (el.open) collapseOthers(el);
    });
  });

  document.querySelectorAll<HTMLElement>("summary[data-nav-group]").forEach((summary) => {
    summary.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === " ") {
        e.preventDefault();
        (summary.parentElement as HTMLDetailsElement).open = !(summary.parentElement as HTMLDetailsElement).open;
      }
    });
  });
</script>

<style>
  nav {
    border-right: 1px solid var(--tk-border);
    padding: 1rem 0;
    overflow-y: auto;
    background: var(--tk-bg-surface);
  }

  @media (max-width: 768px) {
    nav {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 16rem;
      transform: translateX(-100%);
      transition: transform 200ms ease;
      z-index: 10;
    }

    :global(body.nav-open) nav {
      transform: translateX(0);
    }
  }

  details > summary {
    padding: 0.4rem 1rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
  }

  details > summary::-webkit-details-marker { display: none; }

  .tile-link {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: capitalize;
    letter-spacing: 0.03em;
    color: var(--tk-text-muted);
    text-decoration: none;
    flex: 1;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tile-link:hover,
  .tile-link--active {
    color: var(--tk-color-white);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  ul a {
    display: block;
    padding: 0.3rem 1rem 0.3rem 1.5rem;
    font-size: 0.875rem;
    color: var(--tk-text);
  }

  ul a:hover {
    background: var(--tk-bg-hover);
    text-decoration: none;
  }

  ul a[aria-current="page"] {
    color: var(--tk-accent);
    background: var(--tk-bg-hover);
    font-weight: 500;
  }
</style>
