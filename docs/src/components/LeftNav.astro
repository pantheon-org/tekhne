---
import { getCollection } from "astro:content";
import { buildSkillToTileMap, loadPublicTiles } from "../lib/tiles";

const entries = await getCollection("docs");
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const skillToTile = buildSkillToTileMap();
const publicTiles = loadPublicTiles();

interface NavItem {
  label: string;
  href: string;
  active: boolean;
}

interface TileGroup {
  tileSlug: string;
  tileLabel: string;
  tileLandingHref: string;
  hasActive: boolean;
  items: NavItem[];
}

interface DomainGroup {
  domain: string;
  hasActive: boolean;
  tiles: TileGroup[];
}

const tileMap = new Map<string, NavItem[]>();

for (const entry of entries) {
  if (!entry.id.endsWith("/skill") && !entry.id.endsWith("/SKILL.mdx")) continue;
  const data = entry.data as Record<string, unknown>;
  const skillName = data.name as string | undefined;
  if (!skillName) continue;

  const tile = skillToTile.get(skillName);
  if (!tile) continue;

  const parts = entry.id.split("/");
  const skillsIdx = parts.indexOf("skills");
  const skillPath = skillsIdx >= 0 ? parts.slice(skillsIdx + 1).join("/") : entry.id;
  const href = `${base}/skills/${skillPath.replace(/\/skill$/, "/skill/")}/`;
  const active = currentPath === href || currentPath.startsWith(`${href.replace(/\/$/, "")}/`);

  const meta = (data.metadata as Record<string, unknown>) ?? {};
  const label =
    (meta.displayTitle as string | undefined) ??
    (data.name as string | undefined) ??
    entry.data.title;

  if (!tileMap.has(tile.slug)) tileMap.set(tile.slug, []);
  tileMap.get(tile.slug)!.push({ label, href, active });
}

const domainMap = new Map<string, TileGroup[]>();

for (const tile of publicTiles) {
  const items = tileMap.get(tile.slug);
  if (!items || items.length === 0) continue;
  items.sort((a, b) => a.label.localeCompare(b.label));
  const tileLabel = tile.name.replace(/^[^/]+\//, "").replace(/-/g, " ");
  const hasActive = items.some((i) => i.active);
  const domain = tile.tilePath.split("/")[0] ?? "other";

  if (!domainMap.has(domain)) domainMap.set(domain, []);
  domainMap.get(domain)!.push({
    tileSlug: tile.slug,
    tileLabel,
    tileLandingHref: `${base}/tiles/${tile.slug}/`,
    hasActive,
    items,
  });
}

const domainGroups: DomainGroup[] = [];
for (const [domain, tiles] of domainMap) {
  tiles.sort((a, b) => a.tileLabel.localeCompare(b.tileLabel));
  domainGroups.push({
    domain,
    hasActive: tiles.some((t) => t.hasActive),
    tiles,
  });
}
domainGroups.sort((a, b) => a.domain.localeCompare(b.domain));
---

<nav id="left-nav" aria-label="Skill navigation">
  {domainGroups.map((dg) => (
    <details
      data-domain={dg.domain}
      open={dg.hasActive || undefined}
    >
      <summary data-nav-group={dg.domain} tabindex="0">
        {dg.domain.replace(/-/g, "\u00A0")}
      </summary>
      <div class="domain-tiles">
        {dg.tiles.map((tg) => (
          <details
            data-tile={tg.tileSlug}
            open={tg.hasActive || undefined}
          >
            <summary data-nav-tile={tg.tileSlug} tabindex="0">
              <a
                href={tg.tileLandingHref}
                class:list={["tile-link", tg.hasActive && "tile-link--active"]}
                onclick="event.stopPropagation()"
              >
                {tg.tileLabel}
              </a>
            </summary>
            <ul>
              {tg.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={item.active ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        ))}
      </div>
    </details>
  ))}
</nav>

<script>
  const domainDetails = () =>
    document.querySelectorAll<HTMLDetailsElement>("details[data-domain]");
  const tileDetails = () =>
    document.querySelectorAll<HTMLDetailsElement>("details[data-tile]");

  document.addEventListener("DOMContentLoaded", () => {
    domainDetails().forEach((el) => {
      if (!el.querySelector("[aria-current='page']")) el.open = false;
    });
    tileDetails().forEach((el) => {
      if (!el.querySelector("[aria-current='page']")) el.open = false;
    });
  });

  domainDetails().forEach((el) => {
    el.addEventListener("toggle", () => {
      if (el.open) {
        domainDetails().forEach((other) => {
          if (other !== el) other.open = false;
        });
      }
    });
  });

  tileDetails().forEach((el) => {
    el.addEventListener("toggle", () => {
      if (el.open) {
        const parentDomain = el.closest("details[data-domain]");
        tileDetails().forEach((other) => {
          if (other !== el && other.closest("details[data-domain]") === parentDomain) {
            other.open = false;
          }
        });
      }
    });
  });

  document.querySelectorAll<HTMLElement>("summary[data-nav-group], summary[data-nav-tile]").forEach((summary) => {
    summary.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === " ") {
        e.preventDefault();
        const parent = summary.parentElement as HTMLDetailsElement;
        parent.open = !parent.open;
      }
    });
  });
</script>

<style>
  nav {
    border-right: 1px solid var(--tk-border);
    padding: 1rem 0;
    overflow-y: auto;
    background: var(--tk-bg-surface);
  }

  @media (max-width: 768px) {
    nav {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 16rem;
      transform: translateX(-100%);
      transition: transform 200ms ease;
      z-index: 10;
    }

    :global(body.nav-open) nav {
      transform: translateX(0);
    }
  }

  details[data-domain] > summary {
    padding: 0.4rem 1rem;
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--tk-text-muted);
  }

  details[data-domain] > summary::-webkit-details-marker { display: none; }

  details[data-domain] > summary:hover {
    color: var(--tk-color-white);
  }

  .domain-tiles {
    padding-bottom: 0.25rem;
  }

  details[data-tile] > summary {
    padding: 0.3rem 1rem 0.3rem 1.25rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
  }

  details[data-tile] > summary::-webkit-details-marker { display: none; }

  .tile-link {
    font-weight: 500;
    font-size: 0.8rem;
    text-transform: capitalize;
    color: var(--tk-text-muted);
    text-decoration: none;
    flex: 1;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tile-link:hover,
  .tile-link--active {
    color: var(--tk-color-white);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  ul a {
    display: block;
    padding: 0.28rem 1rem 0.28rem 2rem;
    font-size: 0.8rem;
    color: var(--tk-text);
  }

  ul a:hover {
    background: var(--tk-bg-hover);
    text-decoration: none;
  }

  ul a[aria-current="page"] {
    color: var(--tk-accent);
    background: var(--tk-bg-hover);
    font-weight: 500;
  }
</style>
