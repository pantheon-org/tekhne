---
const base = import.meta.env.BASE_URL;
---

<a href={`${base}/`} class="site-logo">
  <svg
    class="site-logo__icon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    fill="currentColor"
  >
    <polygon points="12,1 23,7 1,7" />
    <rect x="1"  y="8"  width="22" height="2" />
    <rect x="3"  y="10" width="3"  height="10" />
    <rect x="10.5" y="10" width="3" height="10" />
    <rect x="18" y="10" width="3"  height="10" />
    <rect x="1"  y="20" width="22" height="2" />
    <rect x="0"  y="22" width="24" height="2" />
  </svg>
  <span>Tekhne</span>
</a>

<style>
  .site-logo {
    display: inline-flex;
    align-items: flex-end;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--tk-color-white);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
    line-height: 1;
  }

  .site-logo__icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--tk-color-white);
    flex-shrink: 0;
  }
</style>
