---
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}/`}
  class="inline-flex items-end gap-[0.65rem] no-underline text-tk-white hover:no-underline font-bold text-[1.4rem] tracking-[0.08em] uppercase flex-shrink-0 leading-none"
>
  <svg
    class="w-6 h-6 text-tk-white flex-shrink-0"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    aria-hidden="true"
    fill="currentColor"
  >
    <polygon points="12,1 23,7 1,7" />
    <rect x="1"  y="8"  width="22" height="2" />
    <rect x="3"  y="10" width="3"  height="10" />
    <rect x="10.5" y="10" width="3" height="10" />
    <rect x="18" y="10" width="3"  height="10" />
    <rect x="1"  y="20" width="22" height="2" />
    <rect x="0"  y="22" width="24" height="2" />
  </svg>
  <span>Tekhne</span>
</a>
