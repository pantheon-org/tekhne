---
/**
 * SkillTabs — wraps skill page content in a four-tab layout.
 *
 * Tabs:
 *   Skill      — the rendered SKILL.md content (default slot)
 *   Audit      — list of dated audit snapshots, each showing a scorecard
 *   Evals      — list of eval scenarios from evals/summary.json
 *   References — list picker for inline rendered reference docs
 *
 * Only rendered on skill pages (entry ID ends with /skill).
 * On other pages the default slot is rendered as-is.
 */

import { getCollection, render } from "astro:content";

const { entry } = Astro.locals.starlightRoute;
const isSkillPage = (entry.id as string).endsWith("/skill");

// biome-ignore lint/suspicious/noExplicitAny: Starlight entry data is not typed for custom fields
const data = entry.data as Record<string, any>;

type RefMeta = { slug: string; title: string };
const skillRefsMeta: RefMeta[] = data.skillRefs ?? [];

type DimensionScores = Record<string, number>;
type AuditData = {
  skill?: string;
  date?: string;
  auditDate?: string;
  dimensions?: DimensionScores;
  total?: number;
  totalScore?: number;
  maxTotal?: number;
  grade?: string;
  lines?: number;
  fileSize?: number;
  hasReferences?: boolean;
  referenceCount?: number;
};

type EvalScenario = {
  id: string;
  capability?: string;
  feasible?: boolean;
  reason?: string;
};

const skillAudit: AuditData | null = data.skillAudit ?? null;
const skillAudits: AuditData[] = data.skillAudits ?? [];
const skillEvals: EvalScenario[] = data.skillEvals ?? [];

// Entry IDs look like "skills/documentation/markdown-authoring/SKILL.mdx"
const idParts = (entry.id as string).split("/");
const skillSlugParts = idParts.slice(0, -1); // drop "SKILL.mdx"
const refIdPrefix = `${skillSlugParts.join("/")}/references/`;

// Fetch and render all reference entries for this skill at build time.
// biome-ignore lint/suspicious/noExplicitAny: Astro component render type is not typed
type RenderedRef = { slug: string; title: string; Content: any };
let renderedRefs: RenderedRef[] = [];

if (isSkillPage && skillRefsMeta.length > 0) {
  const allDocs = await getCollection("docs");
  const refEntries = allDocs.filter((e) => e.id.startsWith(refIdPrefix));

  renderedRefs = await Promise.all(
    skillRefsMeta.map(async (meta) => {
      const docEntry = refEntries.find(
        (e) => e.id === `${refIdPrefix}${meta.slug}.md`,
      );
      if (!docEntry)
        return { slug: meta.slug, title: meta.title, Content: null };
      const { Content } = await render(docEntry);
      return { slug: meta.slug, title: meta.title, Content };
    }),
  );
}

const DIMENSION_LABELS: Record<string, string> = {
  knowledgeDelta: "Knowledge Delta",
  mindsetProcedures: "Mindset & Procedures",
  antiPatternQuality: "Anti-Pattern Quality",
  specificationCompliance: "Specification Compliance",
  progressiveDisclosure: "Progressive Disclosure",
  freedomCalibration: "Freedom Calibration",
  patternRecognition: "Pattern Recognition",
  practicalUsability: "Practical Usability",
  evalValidation: "Eval Validation",
};

const DIMENSION_MAX = 16;

const gradeClass = (grade?: string) =>
  grade
    ? `skill-badge--${grade
        .toLowerCase()
        .replace("+", "-plus")
        .replace(/([a-z])-$/, "$1-minus")}`
    : "skill-badge--unknown";

const latestGrade = skillAudit?.grade;
const auditCount = skillAudits.length;
const evalsCount = skillEvals.length;
const refsCount = renderedRefs.length;

const getAuditTotal = (a: AuditData) => a.total ?? a.totalScore;
const getAuditMax = (a: AuditData) => a.maxTotal ?? 120;
const getAuditDate = (a: AuditData) => a.date ?? a.auditDate;
---

{
  isSkillPage ? (
    <div class="sk-tabs" id="sk-tabs">
      <nav class="sk-tabs__nav" role="tablist" aria-label="Skill sections">
        <button
          class="sk-tabs__btn sk-tabs__btn--active"
          role="tab"
          data-tab="skill"
          aria-selected="true"
          aria-controls="sk-panel-skill"
        >
          Skill
        </button>

        <button
          class="sk-tabs__btn"
          role="tab"
          data-tab="audit"
          aria-selected="false"
          aria-controls="sk-panel-audit"
        >
          Audit
          {latestGrade && (
            <span class:list={["skill-badge", gradeClass(latestGrade)]}>
              {latestGrade}
            </span>
          )}
          {auditCount > 0 && (
            <span class="sk-tabs__count">{auditCount}</span>
          )}
        </button>

        <button
          class="sk-tabs__btn"
          role="tab"
          data-tab="evals"
          aria-selected="false"
          aria-controls="sk-panel-evals"
        >
          Evals
          {evalsCount > 0 && (
            <span class="sk-tabs__count">{evalsCount}</span>
          )}
        </button>

        {refsCount > 0 && (
          <button
            class="sk-tabs__btn"
            role="tab"
            data-tab="refs"
            aria-selected="false"
            aria-controls="sk-panel-refs"
          >
            References
            <span class="sk-tabs__count">{refsCount}</span>
          </button>
        )}
      </nav>

      {/* Skill content panel */}
      <div
        id="sk-panel-skill"
        class="sk-tabs__panel sk-tabs__panel--active"
        role="tabpanel"
        data-panel="skill"
      >
        <slot />
      </div>

      {/* Audit panel — list of dated snapshots */}
      <div
        id="sk-panel-audit"
        class="sk-tabs__panel"
        role="tabpanel"
        data-panel="audit"
        hidden
      >
        {skillAudits.length > 0 ? (
          <div class="sk-audit-list">
            <div class="sk-audit-list__nav" aria-label="Audit dates">
              {skillAudits.map((snapshot, i) => (
                <button
                  class:list={["sk-audit-list__btn", i === 0 && "sk-audit-list__btn--active"]}
                  data-audit={String(i)}
                >
                  <span class="sk-audit-list__date">{getAuditDate(snapshot) ?? "Unknown"}</span>
                  {snapshot.grade && (
                    <span class:list={["skill-badge", "sk-audit-list__grade", gradeClass(snapshot.grade)]}>
                      {snapshot.grade}
                    </span>
                  )}
                </button>
              ))}
            </div>

            <div class="sk-audit-list__content">
              {skillAudits.map((snapshot, i) => (
                <div
                  class:list={["sk-audit", i === 0 && "sk-audit--active"]}
                  data-audit-panel={String(i)}
                  hidden={i !== 0}
                >
                  <div class="sk-audit__summary">
                    <div class="sk-audit__score">
                      <span class="sk-audit__score-value">
                        {getAuditTotal(snapshot) ?? "–"}
                      </span>
                      <span class="sk-audit__score-max">
                        / {getAuditMax(snapshot)}
                      </span>
                    </div>
                    {snapshot.grade && (
                      <span class:list={["skill-badge", "sk-audit__grade", gradeClass(snapshot.grade)]}>
                        {snapshot.grade}
                      </span>
                    )}
                  </div>

                  {snapshot.dimensions && (
                    <div class="sk-audit__dimensions">
                      {Object.entries(snapshot.dimensions).map(
                        ([key, score]: [string, number]) => {
                          const pct = Math.round((score / DIMENSION_MAX) * 100);
                          return (
                            <div class="sk-dim">
                              <div class="sk-dim__header">
                                <span class="sk-dim__label">
                                  {DIMENSION_LABELS[key] ?? key}
                                </span>
                                <span class="sk-dim__score">
                                  {score}/{DIMENSION_MAX}
                                </span>
                              </div>
                              <div class="sk-dim__bar-track">
                                <div
                                  class="sk-dim__bar-fill"
                                  style={`width: ${Math.min(pct, 100)}%`}
                                  data-pct={pct}
                                />
                              </div>
                            </div>
                          );
                        },
                      )}
                    </div>
                  )}

                  {(snapshot.lines !== undefined || snapshot.fileSize !== undefined) && (
                    <p class="sk-audit__meta">
                      {snapshot.lines !== undefined && `${snapshot.lines} lines`}
                      {snapshot.fileSize !== undefined && `${snapshot.fileSize} lines`}
                      {snapshot.referenceCount !== undefined &&
                        ` · ${snapshot.referenceCount} reference${snapshot.referenceCount !== 1 ? "s" : ""}`}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        ) : skillAudit ? (
          <div class="sk-audit sk-audit--active">
            <div class="sk-audit__summary">
              <div class="sk-audit__score">
                <span class="sk-audit__score-value">
                  {skillAudit.total ?? "–"}
                </span>
                <span class="sk-audit__score-max">
                  / {skillAudit.maxTotal ?? 120}
                </span>
              </div>
              {skillAudit.grade && (
                <span class:list={["skill-badge", "sk-audit__grade", gradeClass(skillAudit.grade)]}>
                  {skillAudit.grade}
                </span>
              )}
            </div>

            {skillAudit.dimensions && (
              <div class="sk-audit__dimensions">
                {Object.entries(skillAudit.dimensions).map(
                  ([key, score]: [string, number]) => {
                    const pct = Math.round((score / DIMENSION_MAX) * 100);
                    return (
                      <div class="sk-dim">
                        <div class="sk-dim__header">
                          <span class="sk-dim__label">
                            {DIMENSION_LABELS[key] ?? key}
                          </span>
                          <span class="sk-dim__score">
                            {score}/{DIMENSION_MAX}
                          </span>
                        </div>
                        <div class="sk-dim__bar-track">
                          <div
                            class="sk-dim__bar-fill"
                            style={`width: ${Math.min(pct, 100)}%`}
                            data-pct={pct}
                          />
                        </div>
                      </div>
                    );
                  },
                )}
              </div>
            )}

            {skillAudit.lines !== undefined && (
              <p class="sk-audit__meta">
                {skillAudit.lines} lines
                {skillAudit.referenceCount !== undefined &&
                  ` · ${skillAudit.referenceCount} reference${skillAudit.referenceCount !== 1 ? "s" : ""}`}
              </p>
            )}
          </div>
        ) : (
          <p class="sk-empty">No audit data available.</p>
        )}
      </div>

      {/* Evals panel */}
      <div
        id="sk-panel-evals"
        class="sk-tabs__panel"
        role="tabpanel"
        data-panel="evals"
        hidden
      >
        {skillEvals.length > 0 ? (
          <div class="sk-evals">
            <div class="sk-evals__nav" aria-label="Eval scenarios">
              {skillEvals.map((scenario, i) => (
                <button
                  class:list={["sk-evals__btn", i === 0 && "sk-evals__btn--active"]}
                  data-eval={String(i)}
                >
                  <span class="sk-evals__id">{scenario.id}</span>
                  {scenario.feasible !== undefined && (
                    <span class:list={["sk-evals__feasible", scenario.feasible ? "sk-evals__feasible--yes" : "sk-evals__feasible--no"]}>
                      {scenario.feasible ? "feasible" : "infeasible"}
                    </span>
                  )}
                </button>
              ))}
            </div>

            <div class="sk-evals__content">
              {skillEvals.map((scenario, i) => (
                <div
                  class:list={["sk-evals__doc", i === 0 && "sk-evals__doc--active"]}
                  data-eval-panel={String(i)}
                  hidden={i !== 0}
                >
                  {scenario.capability && (
                    <p class="sk-evals__capability">{scenario.capability}</p>
                  )}
                  {scenario.reason && (
                    <p class="sk-evals__reason">{scenario.reason}</p>
                  )}
                </div>
              ))}
            </div>
          </div>
        ) : (
          <p class="sk-empty">No eval scenarios available.</p>
        )}
      </div>

      {/* References panel — inline rendered content */}
      {renderedRefs.length > 0 && (
        <div
          id="sk-panel-refs"
          class="sk-tabs__panel"
          role="tabpanel"
          data-panel="refs"
          hidden
        >
          <div class="sk-refs">
            <nav class="sk-refs__nav" aria-label="Reference documents">
              {renderedRefs.map((ref, i) => (
                <button
                  class:list={["sk-refs__btn", i === 0 && "sk-refs__btn--active"]}
                  data-ref={ref.slug}
                >
                  {ref.title}
                </button>
              ))}
            </nav>

            <div class="sk-refs__content">
              {renderedRefs.map((ref, i) =>
                ref.Content ? (
                  <div
                    class:list={["sk-refs__doc", "sl-markdown-content", i === 0 && "sk-refs__doc--active"]}
                    data-ref-doc={ref.slug}
                    hidden={i !== 0}
                  >
                    <ref.Content />
                  </div>
                ) : null,
              )}
            </div>
          </div>
        </div>
      )}
    </div>
  ) : (
    <slot />
  )
}

<script>
  const tabs = document.getElementById("sk-tabs");
  if (tabs) {
    tabs.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-tab]");
      if (!btn) return;
      const target = btn.dataset.tab;

      tabs.querySelectorAll<HTMLButtonElement>("[data-tab]").forEach((b) => {
        const active = b.dataset.tab === target;
        b.classList.toggle("sk-tabs__btn--active", active);
        b.setAttribute("aria-selected", String(active));
      });
      tabs.querySelectorAll<HTMLElement>("[data-panel]").forEach((p) => {
        const active = p.dataset.panel === target;
        p.classList.toggle("sk-tabs__panel--active", active);
        p.hidden = !active;
      });
    });

    tabs.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-ref]");
      if (!btn) return;
      const target = btn.dataset.ref;

      tabs.querySelectorAll<HTMLButtonElement>("[data-ref]").forEach((b) => {
        b.classList.toggle("sk-refs__btn--active", b.dataset.ref === target);
      });
      tabs.querySelectorAll<HTMLElement>("[data-ref-doc]").forEach((p) => {
        const active = p.dataset.refDoc === target;
        p.classList.toggle("sk-refs__doc--active", active);
        p.hidden = !active;
      });
    });

    tabs.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-audit]");
      if (!btn || btn.hasAttribute("data-tab")) return;
      const target = btn.dataset.audit;

      tabs.querySelectorAll<HTMLButtonElement>("[data-audit]").forEach((b) => {
        if (!b.hasAttribute("data-tab"))
          b.classList.toggle("sk-audit-list__btn--active", b.dataset.audit === target);
      });
      tabs.querySelectorAll<HTMLElement>("[data-audit-panel]").forEach((p) => {
        const active = p.dataset.auditPanel === target;
        p.classList.toggle("sk-audit--active", active);
        p.hidden = !active;
      });
    });

    tabs.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-eval]");
      if (!btn || btn.hasAttribute("data-tab")) return;
      const target = btn.dataset.eval;

      tabs.querySelectorAll<HTMLButtonElement>("[data-eval]").forEach((b) => {
        if (!b.hasAttribute("data-tab"))
          b.classList.toggle("sk-evals__btn--active", b.dataset.eval === target);
      });
      tabs.querySelectorAll<HTMLElement>("[data-eval-panel]").forEach((p) => {
        const active = p.dataset.evalPanel === target;
        p.classList.toggle("sk-evals__doc--active", active);
        p.hidden = !active;
      });
    });
  }
</script>

<style>
  /* ── Tab nav ─────────────────────────────────────────────── */

  .sk-tabs__nav {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid var(--sl-color-hairline-medium);
    margin-bottom: 1.5rem;
  }

  .sk-tabs__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    font-size: var(--sl-text-sm);
    font-family: inherit;
    color: var(--sl-color-gray-2);
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .sk-tabs__btn:hover {
    color: var(--sl-color-white);
  }

  .sk-tabs__btn--active {
    color: var(--sl-color-white);
    border-bottom-color: var(--sl-color-accent);
    font-weight: 600;
  }

  .sk-tabs__count {
    display: inline-block;
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    border-radius: 9999px;
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.1em 0.5em;
  }

  /* ── Panels ─────────────────────────────────────────────── */

  .sk-tabs__panel {
    display: none;
  }

  .sk-tabs__panel--active {
    display: block;
  }

  /* ── Shared sidebar list layout ─────────────────────────── */

  .sk-audit-list,
  .sk-evals {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .sk-audit-list,
    .sk-evals {
      grid-template-columns: 1fr;
    }
  }

  /* ── Audit snapshot list ────────────────────────────────── */

  .sk-audit-list__nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    position: sticky;
    top: var(--sl-nav-height, 3.5rem);
  }

  .sk-audit-list__btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.75rem;
    background: none;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: var(--sl-text-xs);
    font-family: inherit;
    color: var(--sl-color-gray-2);
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }

  .sk-audit-list__btn:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .sk-audit-list__btn--active {
    background: var(--sl-color-gray-5);
    border-color: var(--sl-color-hairline-medium);
    color: var(--sl-color-white);
    font-weight: 500;
  }

  .sk-audit-list__date {
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
  }

  .sk-audit-list__grade {
    font-size: 0.65rem !important;
    padding: 0.1em 0.4em !important;
  }

  .sk-audit-list__content {
    min-width: 0;
  }

  /* ── Audit scorecard ────────────────────────────────────── */

  .sk-audit {
    display: none;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sk-audit--active {
    display: flex;
  }

  .sk-audit__summary {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sk-audit__score {
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
  }

  .sk-audit__score-value {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    color: var(--sl-color-white);
  }

  .sk-audit__score-max {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }

  .sk-audit__grade {
    font-size: 1rem !important;
    padding: 0.25em 0.75em !important;
  }

  .sk-audit__dimensions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sk-dim__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.3rem;
  }

  .sk-dim__label {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
  }

  .sk-dim__score {
    font-size: var(--sl-text-xs);
    font-family: var(--sl-font-mono);
    color: var(--sl-color-gray-3);
  }

  .sk-dim__bar-track {
    height: 6px;
    background: var(--sl-color-gray-5);
    border-radius: 9999px;
    overflow: hidden;
  }

  .sk-dim__bar-fill {
    height: 100%;
    border-radius: 9999px;
    background: var(--sl-color-accent);
    transition: width 0.4s ease;
  }

  .sk-audit__meta {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  /* ── Evals panel ────────────────────────────────────────── */

  .sk-evals__nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    position: sticky;
    top: var(--sl-nav-height, 3.5rem);
  }

  .sk-evals__btn {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 0.2rem;
    width: 100%;
    text-align: left;
    padding: 0.45rem 0.75rem;
    background: none;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: var(--sl-text-xs);
    font-family: inherit;
    color: var(--sl-color-gray-2);
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }

  .sk-evals__btn:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .sk-evals__btn--active {
    background: var(--sl-color-gray-5);
    border-color: var(--sl-color-hairline-medium);
    color: var(--sl-color-white);
    font-weight: 500;
  }

  .sk-evals__id {
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    line-height: 1.3;
  }

  .sk-evals__feasible {
    font-size: 0.65rem;
    border-radius: 9999px;
    padding: 0.1em 0.5em;
    font-weight: 500;
  }

  .sk-evals__feasible--yes {
    background: color-mix(in srgb, var(--sl-color-green) 15%, transparent);
    color: var(--sl-color-green);
  }

  .sk-evals__feasible--no {
    background: color-mix(in srgb, var(--sl-color-orange) 15%, transparent);
    color: var(--sl-color-orange);
  }

  .sk-evals__content {
    min-width: 0;
  }

  .sk-evals__doc {
    display: none;
  }

  .sk-evals__doc--active {
    display: block;
  }

  .sk-evals__capability {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-white);
    font-weight: 500;
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .sk-evals__reason {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.6;
  }

  /* ── References layout ──────────────────────────────────── */

  .sk-refs {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 640px) {
    .sk-refs {
      grid-template-columns: 1fr;
    }
  }

  .sk-refs__nav {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    position: sticky;
