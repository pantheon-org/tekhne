---
interface Props {
  title: string;
  description?: string;
  href: string;
  domain?: string;
  grade?: string;
  evalCount?: number;
  auditDate?: string;
}
const { title, description, href, domain, grade, evalCount, auditDate } = Astro.props;
const gradeClass = grade
  ? `skill-badge--${grade.toLowerCase().replace("+", "-plus").replace(/([a-z])-$/, "$1-minus")}`
  : "skill-badge--unknown";
---

<article
  class="skill-card"
  data-tile-card
  data-domain={domain ?? ""}
  data-grade={grade ?? ""}
>
  <a href={href} class="skill-card__title">{title}</a>
  <div class="skill-card__chips">
    {domain && <span class="skill-card__domain">{domain}</span>}
    {grade && <span class:list={["skill-badge", gradeClass]}>{grade}</span>}
  </div>
  {description && <p class="skill-card__desc">{description}</p>}
  {(evalCount != null || auditDate) && (
    <footer class="skill-card__meta">
      {evalCount != null && <span>{evalCount} eval{evalCount !== 1 ? "s" : ""}</span>}
      {auditDate && <time datetime={auditDate}>{auditDate.slice(0, 10)}</time>}
    </footer>
  )}
</article>

<style>
  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--tk-bg-surface);
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    padding: 1rem;
    transition: border-color 0.15s, background 0.15s;
  }

  .skill-card:hover {
    border-color: var(--tk-accent);
    background: var(--tk-bg-hover);
  }

  .skill-card__title {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--tk-color-white);
    text-decoration: none;
  }

  .skill-card__title:hover {
    text-decoration: underline;
  }

  .skill-card__chips {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .skill-card__domain {
    font-size: 0.7rem;
    background: var(--tk-bg-elevated);
    border: 1px solid var(--tk-border);
    border-radius: 9999px;
    padding: 0.1em 0.5em;
    color: var(--tk-text-muted);
  }

  .skill-card__desc {
    font-size: 0.8rem;
    color: var(--tk-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .skill-card__meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.72rem;
    color: var(--tk-color-gray-3);
    margin-top: auto;
    padding-top: 0.25rem;
  }
</style>
