---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-4">
  <ol class="flex flex-wrap items-center gap-1 list-none p-0 m-0 text-[0.8rem] text-tk-muted">
    {crumbs.map((crumb, i) => (
      <li class="flex items-center gap-1">
        {crumb.href && i < crumbs.length - 1
          ? <a href={crumb.href} class="text-tk-muted hover:text-tk-link">{crumb.label}</a>
          : <span aria-current="page">{crumb.label}</span>}
        {i < crumbs.length - 1 && <span aria-hidden="true" class="text-tk-border">/</span>}
      </li>
    ))}
  </ol>
</nav>
