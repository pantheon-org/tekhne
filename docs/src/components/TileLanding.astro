---
import type { CollectionEntry } from "astro:content";
import type { TileData } from "../lib/tiles";

interface Props {
  tile: TileData;
  skillEntries: CollectionEntry<"docs">[];
}

const { tile, skillEntries } = Astro.props;
const base = import.meta.env.BASE_URL;

const tessInstallCmd = `npx tessl install ${tile.name}`;

interface SkillInfo {
  key: string;
  title: string;
  description: string | undefined;
  grade: string | undefined;
  href: string;
}

const skills: SkillInfo[] = Object.keys(tile.skills).map((key) => {
  const entry = skillEntries.find((e) => {
    const d = e.data as Record<string, unknown>;
    return d.name === key;
  });
  if (!entry) return { key, title: key, description: undefined, grade: undefined, href: "#" };
  const d = entry.data as Record<string, unknown>;
  const meta = (d.metadata as Record<string, unknown>) ?? {};
  const title = (meta.displayTitle as string | undefined) ?? (d.name as string | undefined) ?? key;
  const description = d.description as string | undefined;
  const audit = (d.skillAudit as Record<string, unknown>) ?? {};
  const grade = (meta.grade as string | undefined) ?? (audit.grade as string | undefined);
  const parts = entry.id.split("/");
  const skillsIdx = parts.indexOf("skills");
  const skillPath = skillsIdx >= 0 ? parts.slice(skillsIdx + 1).join("/") : entry.id;
  const href = `${base}/skills/${skillPath.replace(/\/skill$/, "/skill/")}/`;
  return { key, title, description, grade, href };
});

const gradeClass = (grade?: string) =>
  grade
    ? `skill-badge--${grade.toLowerCase().replace("+", "-plus").replace(/([a-z])-$/, "$1-minus")}`
    : "skill-badge--unknown";

const tileDomain = tile.tilePath.split("/")[0] ?? "";
---

<div class="tile-landing">
  <div class="tile-header">
    <div class="tile-header__meta">
      {tileDomain && <span class="tile-badge tile-domain">{tileDomain.replace(/-/g, "\u00A0")}</span>}
      {tile.private ? (
        <span class="tile-badge tile-version">v{tile.version}</span>
      ) : (
        <a
          class="tile-badge tile-version"
          href={`https://tessl.io/registry/skills/${tile.name}`}
          target="_blank"
          rel="noopener noreferrer"
        >v{tile.version}</a>
      )}
      <span class="tile-badge tile-skills-count">{skills.length} skill{skills.length !== 1 ? "s" : ""}</span>
      {tile.private ? (
        <span class="tile-badge tile-visibility tile-visibility--private">private</span>
      ) : (
        <span class="tile-badge tile-visibility tile-visibility--public">public</span>
      )}
    </div>
    <h1 class="tile-title">{tile.name}</h1>
    {tile.summary && <p class="tile-summary">{tile.summary}</p>}

    <div class="sk-install">
      <div class="sk-install__tabs">
        <button class="sk-install__tab sk-install__tab--active" data-install-tab="tessl">npx tessl</button>
      </div>
      <div class="sk-install__panel sk-install__panel--active" data-install-panel="tessl">
        <code class="sk-install__cmd">{tessInstallCmd}</code>
        <button
          class="sk-install__copy"
          type="button"
          aria-label="Copy install command"
          data-copy={tessInstallCmd}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        </button>
      </div>
    </div>
  </div>

  <section class="tile-skills">
    <h2 class="tile-skills__heading">Skills</h2>
    <div class="tile-skills__grid">
      {skills.map((skill) => (
        <a href={skill.href} class="skill-entry">
          <div class="skill-entry__top">
            <span class="skill-entry__name">{skill.title}</span>
            {skill.grade && (
              <span class:list={["skill-badge", "skill-entry__grade", gradeClass(skill.grade)]}>
                {skill.grade}
              </span>
            )}
          </div>
          {skill.description && (
            <p class="skill-entry__desc">{skill.description}</p>
          )}
        </a>
      ))}
    </div>
  </section>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".sk-install__copy").forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = btn.dataset.copy;
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const svg = btn.querySelector("svg");
        if (svg) {
          svg.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
          setTimeout(() => {
            svg.innerHTML =
              '<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>';
          }, 1500);
        }
      });
    });
  });
</script>

<style>
  .tile-header {
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    background: var(--tk-bg-surface);
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }

  .tile-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.875rem;
  }

  .tile-badge {
    display: inline-block;
    padding: 0.2em 0.65em;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .tile-domain {
    background: var(--tk-color-gray-5);
    color: var(--tk-color-gray-2);
    text-transform: capitalize;
  }

  .tile-version {
    background: var(--tk-color-accent-low);
    color: var(--tk-color-accent-high);
    font-family: var(--tk-font-mono);
    text-decoration: none;
  }

  a.tile-version:hover {
    text-decoration: underline;
  }

  .tile-skills-count {
    background: var(--tk-bg-elevated);
    color: var(--tk-text-muted);
    border: 1px solid var(--tk-border);
  }

  .tile-visibility--public {
    background: color-mix(in srgb, var(--tk-color-green) 15%, transparent);
    color: var(--tk-color-green);
  }

  .tile-visibility--private {
    background: var(--tk-bg-elevated);
    color: var(--tk-text-muted);
    border: 1px solid var(--tk-border);
  }

  .tile-title {
    margin: 0 0 0.75rem;
    font-size: 1.875rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--tk-color-white);
  }

  .tile-summary {
    color: var(--tk-color-gray-2);
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }

  .sk-install {
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .sk-install__tabs {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--tk-border);
    background: var(--tk-bg-surface);
    padding: 0 0.5rem;
  }

  .sk-install__tab {
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--tk-text-muted);
    cursor: pointer;
    border: none;
    background: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.12s, border-color 0.12s;
  }

  .sk-install__tab--active {
    color: var(--tk-color-white);
    border-bottom-color: var(--tk-color-accent, #818cf8);
  }

  .sk-install__panel {
    display: none;
    align-items: stretch;
    background: var(--tk-bg-hover);
  }

  .sk-install__panel--active {
    display: flex;
  }

  .sk-install__cmd {
    flex: 1;
    display: block;
    padding: 0.7rem 1rem;
    font-family: var(--tk-font-mono);
    font-size: 0.8rem;
    color: var(--tk-text-muted);
    background: none;
    white-space: nowrap;
    overflow-x: auto;
  }

  .sk-install__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0 0.875rem;
    background: none;
    border: none;
    border-left: 1px solid var(--tk-border);
    color: var(--tk-text-muted);
    cursor: pointer;
    transition: color 0.12s, background 0.12s;
  }

  .sk-install__copy:hover {
    color: var(--tk-color-white);
    background: var(--tk-border);
  }

  .tile-skills__heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--tk-color-white);
    margin-bottom: 1rem;
  }

  .tile-skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }

  .skill-entry {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--tk-bg-surface);
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    padding: 1rem;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .skill-entry:hover {
    border-color: var(--tk-accent);
    background: var(--tk-bg-hover);
  }

  .skill-entry__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .skill-entry__name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--tk-color-white);
  }

  .skill-entry__grade {
    font-size: 0.65rem !important;
    padding: 0.1em 0.4em !important;
    flex-shrink: 0;
  }

  .skill-entry__desc {
    font-size: 0.8rem;
    color: var(--tk-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }
</style>
