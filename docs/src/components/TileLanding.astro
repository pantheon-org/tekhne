---
import type { CollectionEntry } from "astro:content";
import type { TileData } from "../lib/tiles";
import InstallBlock from "./InstallBlock.astro";

interface Props {
  tile: TileData;
  skillEntries: CollectionEntry<"docs">[];
}

const { tile, skillEntries } = Astro.props;
const base = import.meta.env.BASE_URL;

const tessInstallCmd = `npx tessl install ${tile.name}`;

interface SkillInfo {
  key: string;
  title: string;
  description: string | undefined;
  grade: string | undefined;
  href: string;
}

const skills: SkillInfo[] = Object.keys(tile.skills).map((key) => {
  const entry = skillEntries.find((e) => {
    const d = e.data as Record<string, unknown>;
    return d.name === key;
  });
  if (!entry) return { key, title: key, description: undefined, grade: undefined, href: "#" };
  const d = entry.data as Record<string, unknown>;
  const meta = (d.metadata as Record<string, unknown>) ?? {};
  const title = (meta.displayTitle as string | undefined) ?? (d.name as string | undefined) ?? key;
  const description = d.description as string | undefined;
  const audit = (d.skillAudit as Record<string, unknown>) ?? {};
  const grade = (meta.grade as string | undefined) ?? (audit.grade as string | undefined);
  const parts = entry.id.split("/");
  const skillsIdx = parts.indexOf("skills");
  const skillPath = skillsIdx >= 0 ? parts.slice(skillsIdx + 1).join("/") : entry.id;
  const href = `${base}/skills/${skillPath.replace(/\/skill$/, "/skill/")}/`;
  return { key, title, description, grade, href };
});

const gradeClass = (grade?: string) =>
  grade
    ? `skill-badge--${grade.toLowerCase().replace("+", "-plus").replace(/([a-z])-$/, "$1-minus")}`
    : "skill-badge--unknown";

const tileDomain = tile.tilePath.split("/")[0] ?? "";
---

<div class="tile-landing">
  <div class="tile-header">
    <div class="tile-header__meta">
      {tileDomain && <span class="tile-badge tile-domain">{tileDomain.replace(/-/g, "\u00A0")}</span>}
      {tile.private ? (
        <span class="tile-badge tile-version">v{tile.version}</span>
      ) : (
        <a
          class="tile-badge tile-version"
          href={`https://tessl.io/registry/skills/${tile.name}`}
          target="_blank"
          rel="noopener noreferrer"
        >v{tile.version}</a>
      )}
      <span class="tile-badge tile-skills-count">{skills.length} skill{skills.length !== 1 ? "s" : ""}</span>
      {tile.private ? (
        <span class="tile-badge tile-visibility tile-visibility--private">private</span>
      ) : (
        <span class="tile-badge tile-visibility tile-visibility--public">public</span>
      )}
    </div>
    <h1 class="tile-title">{tile.name}</h1>
    {tile.summary && <p class="tile-summary">{tile.summary}</p>}

    <InstallBlock tessInstallCmd={tessInstallCmd} />
  </div>

  <section class="tile-skills">
    <h2 class="tile-skills__heading">Skills</h2>
    <div class="tile-skills__grid">
      {skills.map((skill) => (
        <a href={skill.href} class="skill-entry">
          <div class="skill-entry__top">
            <span class="skill-entry__name">{skill.title}</span>
            {skill.grade && (
              <div class:list={["skill-entry__grade", gradeClass(skill.grade)]}>
                <svg class="skill-entry__shield" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 28" aria-hidden="true">
                  <path
                    d="M12 0 L24 5 L24 14 C24 20.627 18.627 26 12 28 C5.373 26 0 20.627 0 14 L0 5 Z"
                    fill="currentColor"
                    stroke="var(--tk-border)"
                    stroke-width="0.75"
                  />
                </svg>
                <span class="skill-entry__grade-text">{skill.grade}</span>
              </div>
            )}
          </div>
          {skill.description && (
            <p class="skill-entry__desc">{skill.description}</p>
          )}
        </a>
      ))}
    </div>
  </section>
</div>


<style>
  .tile-header {
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    background: var(--tk-bg-surface);
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }

  .tile-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.875rem;
  }

  .tile-badge {
    display: inline-block;
    padding: 0.2em 0.65em;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .tile-domain {
    background: var(--tk-color-gray-5);
    color: var(--tk-color-gray-2);
    text-transform: capitalize;
  }

  .tile-version {
    background: var(--tk-color-accent-low);
    color: var(--tk-color-accent-high);
    font-family: var(--tk-font-mono);
    text-decoration: none;
  }

  a.tile-version:hover {
    text-decoration: underline;
  }

  .tile-skills-count {
    background: var(--tk-bg-elevated);
    color: var(--tk-text-muted);
    border: 1px solid var(--tk-border);
  }

  .tile-visibility--public {
    background: color-mix(in srgb, var(--tk-color-green) 15%, transparent);
    color: var(--tk-color-green);
  }

  .tile-visibility--private {
    background: var(--tk-bg-elevated);
    color: var(--tk-text-muted);
    border: 1px solid var(--tk-border);
  }

  .tile-title {
    margin: 0 0 0.75rem;
    font-size: 1.875rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--tk-color-white);
  }

  .tile-summary {
    color: var(--tk-color-gray-2);
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }

  .tile-skills__heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--tk-color-white);
    margin-bottom: 1rem;
  }

  .tile-skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .skill-entry {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--tk-bg-surface);
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }

  .skill-entry:hover {
    border-color: var(--tk-accent);
    background: var(--tk-bg-hover);
  }

  .skill-entry__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .skill-entry__name {
    font-weight: 600;
    font-size: 1rem;
    color: var(--tk-color-white);
  }

  .skill-entry__grade {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 2rem;
    height: 2.25rem;
  }

  .skill-entry__shield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .skill-entry__grade-text {
    position: relative;
    z-index: 1;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1;
    color: var(--badge-fg, #fff);
    text-shadow: 0 0 1px #27272a, 0 1px 2px rgba(0,0,0,0.4);
  }

  .skill-entry__grade.skill-badge--b-minus .skill-entry__grade-text {
    color: var(--badge-b-minus-fg);
  }

  .skill-entry__grade.skill-badge--a-plus  { color: var(--badge-a-plus-bg); }
  .skill-entry__grade.skill-badge--a       { color: var(--badge-a-bg); }
  .skill-entry__grade.skill-badge--a-minus { color: var(--badge-a-minus-bg); }
  .skill-entry__grade.skill-badge--b-plus  { color: var(--badge-b-plus-bg); }
  .skill-entry__grade.skill-badge--b       { color: var(--badge-b-bg); }
  .skill-entry__grade.skill-badge--b-minus { color: var(--badge-b-minus-bg); }
  .skill-entry__grade.skill-badge--c-plus  { color: var(--badge-c-plus-bg); }
  .skill-entry__grade.skill-badge--c       { color: var(--badge-c-bg); }
  .skill-entry__grade.skill-badge--c-minus { color: var(--badge-c-minus-bg); }
  .skill-entry__grade.skill-badge--d-plus  { color: var(--badge-d-plus-bg); }
  .skill-entry__grade.skill-badge--d       { color: var(--badge-d-bg); }
  .skill-entry__grade.skill-badge--d-minus { color: var(--badge-d-minus-bg); }
  .skill-entry__grade.skill-badge--f       { color: var(--badge-f-bg); }
  .skill-entry__grade.skill-badge--unknown { color: #6b7280; }

  .skill-entry__desc {
    font-size: 0.875rem;
    color: var(--tk-text-muted);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }
</style>
