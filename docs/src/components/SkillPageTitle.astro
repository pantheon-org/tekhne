---
import type { CollectionEntry } from "astro:content";

const PAGE_TITLE_ID = "_top";

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
const isSkillPage = (entry.id as string).endsWith("/skill");

const data = entry.data as Record<string, any>;
const metadata = (data.metadata as Record<string, any>) || {};

const displayTitle: string =
  metadata.displayTitle || data.name || data.title || "Untitled";

const description: string | undefined = data.description;
const version: string | undefined = metadata.version;
const skillAudit = (data.skillAudit as Record<string, any>) || {};
const skillAudits: any[] = data.skillAudits ?? [];
const latestAudit = skillAudits[0] ?? skillAudit;
const grade: string | undefined = metadata.grade ?? latestAudit.grade;
const tags: string[] = metadata.tags ?? [];

const idParts = (entry.id as string).split("/");
const skillsIdx = idParts.indexOf("skills");
const domain: string | undefined =
  skillsIdx >= 0 ? idParts[skillsIdx + 1] : undefined;

const installSlug =
  skillsIdx >= 0 ? idParts.slice(skillsIdx + 1, -1).join("--") : "";

const gradeClass = grade
  ? `skill-badge--${grade
      .toLowerCase()
      .replace("+", "-plus")
      .replace(/([a-z])-$/, "$1-minus")}`
  : "";
---

{
  isSkillPage ? (
    <div class="sk-header">
      {grade && (
        <div class:list={["sk-grade", "skill-badge", gradeClass]}>
          {grade}
        </div>
      )}

      <div class="sk-header__body">
        <div class="sk-header__badges">
          {domain && (
            <span class="sk-badge sk-domain">
              {domain.replace(/-/g, "\u00A0")}
            </span>
          )}
          {version && (
            <span class="sk-badge sk-version">v{version}</span>
          )}
        </div>

        <h1 id={PAGE_TITLE_ID} class="sk-title">
          {displayTitle}
        </h1>

        {description && <p class="sk-desc">{description}</p>}

        {installSlug && (
          <div class="sk-install">
            <span class="sk-install__label">Install</span>
            <code class="sk-install__cmd">
              npx skills add github:pantheon-org/tekhne --skill {installSlug}
            </code>
          </div>
        )}

        {tags.length > 0 && (
          <div class="sk-tags">
            {tags.map((tag: string) => (
              <span class="sk-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>
  ) : (
    <h1 id={PAGE_TITLE_ID}>{entry.data.title}</h1>
  )
}

<style>
  .sk-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    background: var(--tk-bg-surface);
    padding: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .sk-grade {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    border-radius: 0.5rem;
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
  }

  .sk-header__body {
    flex: 1;
    min-width: 0;
  }

  .sk-header__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .sk-title {
    margin: 0 0 0.75rem;
    font-size: 1.875rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--tk-color-white);
  }

  .sk-desc {
    color: var(--tk-color-gray-2);
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0 0 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sk-install {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--tk-bg);
    border: 1px solid var(--tk-border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.875rem;
    overflow-x: auto;
  }

  .sk-install__label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--tk-color-gray-3);
    flex-shrink: 0;
  }

  .sk-install__cmd {
    font-family: var(--tk-font-mono);
    font-size: 0.75rem;
    color: var(--tk-color-gray-1);
    background: none;
    padding: 0;
    border: none;
    white-space: nowrap;
  }

  .sk-badge {
    display: inline-block;
    padding: 0.2em 0.65em;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .sk-domain {
    background: var(--tk-color-gray-5);
    color: var(--tk-color-gray-2);
    text-transform: capitalize;
  }

  .sk-version {
    background: var(--tk-color-accent-low);
    color: var(--tk-color-accent-high);
    font-family: var(--tk-font-mono);
  }

  .sk-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 1rem;
  }

  .sk-tag {
    background: var(--tk-color-gray-5);
    color: var(--tk-color-gray-3);
    border-radius: 9999px;
    padding: 0.15em 0.65em;
    font-size: 0.7rem;
  }
</style>
