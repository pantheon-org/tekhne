---
/**
 * SkillPageTitle — overrides Starlight's default PageTitle.
 *
 * On skill pages (entry ID ends with /skill): renders a tessl.io-style
 * metadata header card showing the skill name, description, domain badge,
 * version, install command, grade, and tags.
 *
 * On all other pages: delegates to the default Starlight PageTitle.
 */
import Default from "@astrojs/starlight/components/PageTitle.astro";
// Starlight 0.38+ uses "_top" as the page title anchor ID
const PAGE_TITLE_ID = "_top";

const { entry } = Astro.locals.starlightRoute;
const isSkillPage = (entry.id as string).endsWith("/skill");

// ── Data extraction ───────────────────────────────────────────────────────────
const data = entry.data as Record<string, any>;
const metadata = (data.metadata as Record<string, any>) || {};

// Prefer the H1 text extracted by prelink over the kebab-case `name` field
const displayTitle: string =
  metadata.displayTitle || data.name || data.title || "Untitled";

const description: string | undefined = data.description;
const version: string | undefined = metadata.version;
const grade: string | undefined = metadata.grade;
const tags: string[] = metadata.tags ?? [];

// ── Domain + install command ──────────────────────────────────────────────────
// Entry IDs look like "skills/ci-cd/github-actions/generator/SKILL.md"
const idParts = (entry.id as string).split("/");
const skillsIdx = idParts.indexOf("skills");
const domain: string | undefined =
  skillsIdx >= 0 ? idParts[skillsIdx + 1] : undefined;

// All path segments between skills/ and SKILL.md, joined with "--"
const installSlug =
  skillsIdx >= 0 ? idParts.slice(skillsIdx + 1, -1).join("--") : "";

// ── Grade CSS class ───────────────────────────────────────────────────────────
const gradeClass = grade
  ? `skill-badge--${grade
      .toLowerCase()
      .replace("+", "-plus")
      .replace(/([a-z])-$/, "$1-minus")}`
  : "";
---

{
  isSkillPage ? (
    <div class="sk-header">
      {/* Top badge row */}
      <div class="sk-header__badges">
        {domain && (
          <span class="sk-badge sk-domain">
            {domain.replace(/-/g, "\u00A0")}
          </span>
        )}
        {version && (
          <span class="sk-badge sk-version">v{version}</span>
        )}
        {grade && (
          <span class:list={["sk-badge", "skill-badge", gradeClass]}>
            {grade}
          </span>
        )}
      </div>

      {/* Title */}
      <h1 id={PAGE_TITLE_ID} class="sk-title">
        {displayTitle}
      </h1>

      {/* Description */}
      {description && <p class="sk-desc">{description}</p>}

      {/* Install command */}
      {installSlug && (
        <div class="sk-install">
          <span class="sk-install__label">Install</span>
          <code class="sk-install__cmd">
            npx skills add github:pantheon-org/tekhne --skill {installSlug}
          </code>
        </div>
      )}

      {/* Tags */}
      {tags.length > 0 && (
        <div class="sk-tags">
          {tags.map((tag: string) => (
            <span class="sk-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  ) : (
    <Default />
  )
}

<style>
  /* ── Skill page header card ─────────────────────────────────────────── */

  .sk-header {
    border: 1px solid var(--sl-color-hairline-medium);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-sidebar);
    padding: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .sk-header__badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .sk-title {
    margin: 0 0 0.75rem;
    font-size: var(--sl-text-3xl);
    font-weight: 600;
    line-height: 1.2;
    color: var(--sl-color-white);
  }

  .sk-desc {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    line-height: 1.65;
    margin: 0 0 1.25rem;
    /* Limit to 4 lines on narrow screens */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Install command block ──────────────────────────────────────────── */

  .sk-install {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-medium);
    border-radius: 0.375rem;
    padding: 0.5rem 0.875rem;
    overflow-x: auto;
  }

  .sk-install__label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--sl-color-gray-3);
    flex-shrink: 0;
  }

  .sk-install__cmd {
    font-family: var(--sl-font-mono);
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-1);
    background: none;
    padding: 0;
    border: none;
    white-space: nowrap;
  }

  /* ── Shared badge base ──────────────────────────────────────────────── */

  .sk-badge {
    display: inline-block;
    padding: 0.2em 0.65em;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .sk-domain {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    text-transform: capitalize;
  }

  .sk-version {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    font-family: var(--sl-font-mono);
  }

  /* ── Tags row ───────────────────────────────────────────────────────── */

  .sk-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 1rem;
  }

  .sk-tag {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
    border-radius: 9999px;
    padding: 0.15em 0.65em;
    font-size: 0.7rem;
  }
</style>
