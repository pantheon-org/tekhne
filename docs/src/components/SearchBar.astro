---
---

<button id="search-trigger" class="search-trigger" aria-label="Search" aria-keyshortcuts="Control+K Meta+K">
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="search-trigger__label">Search</span>
  <kbd class="search-trigger__kbd">⌘K</kbd>
</button>

<div id="search-modal" class="search-modal" hidden>
  <div class="search-modal__backdrop"></div>
  <div class="search-modal__panel">
    <div id="search-input"></div>
  </div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  var pf;

  function openSearch() {
    var modal = document.getElementById("search-modal");
    if (!modal) return;
    modal.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
    if (!pf && typeof window.PagefindUI !== "undefined") {
      pf = new window.PagefindUI({ element: "#search-input", showSubResults: true, resetStyles: false });
    }
    setTimeout(function () {
      var input = modal.querySelector("input");
      if (input) input.focus();
    }, 50);
  }

  function closeSearch() {
    var modal = document.getElementById("search-modal");
    if (!modal) return;
    modal.setAttribute("hidden", "");
    document.body.style.overflow = "";
  }

  window.addEventListener("DOMContentLoaded", function () {
    document.getElementById("search-trigger").addEventListener("click", openSearch);
    document.querySelector(".search-modal__backdrop").addEventListener("click", closeSearch);
    document.addEventListener("keydown", function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") { e.preventDefault(); openSearch(); }
      if (e.key === "Escape") closeSearch();
    });
  });
</script>

<style>
  :global(header) {
    position: relative;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    background: var(--tk-bg);
    color: var(--tk-text-muted);
    cursor: pointer;
    font-size: 0.8125rem;
    font-family: inherit;
    width: 14rem;
    transition: border-color 0.15s, color 0.15s;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .search-trigger:hover {
    border-color: var(--tk-accent);
    color: var(--tk-text);
  }

  .search-trigger__label {
    flex: 1;
    text-align: left;
  }

  .search-trigger__kbd {
    font-size: 0.7rem;
    font-family: var(--tk-font-mono);
    background: var(--tk-bg-surface);
    border: 1px solid var(--tk-border);
    border-radius: 0.25rem;
    padding: 0.1em 0.4em;
    color: var(--tk-text-muted);
  }

  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 6rem;
  }

  .search-modal[hidden] {
    display: none;
  }

  .search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
  }

  .search-modal__panel {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 36rem;
    background: var(--tk-bg-surface);
    border: 1px solid var(--tk-border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    padding: 0.5rem;
  }

  .search-modal__panel :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--tk-accent);
    --pagefind-ui-text: var(--tk-text);
    --pagefind-ui-background: var(--tk-bg-surface);
    --pagefind-ui-border: var(--tk-border);
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-font: inherit;
  }
</style>
