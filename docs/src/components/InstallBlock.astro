---
interface Props {
  tessInstallCmd?: string;
  skillsInstallCmd?: string;
}

const { tessInstallCmd, skillsInstallCmd } = Astro.props;
if (!tessInstallCmd && !skillsInstallCmd) return;

const tessFirst = !!tessInstallCmd;
---

<div class="sk-install">
  <div class="sk-install__tabs">
    {tessInstallCmd && (
      <button
        class:list={["sk-install__tab", tessFirst && "sk-install__tab--active"]}
        data-install-tab="tessl"
      >npx tessl</button>
    )}
    {skillsInstallCmd && (
      <button
        class:list={["sk-install__tab", !tessFirst && "sk-install__tab--active"]}
        data-install-tab="skills"
      >npx skills</button>
    )}
  </div>

  {tessInstallCmd && (
    <div
      class:list={["sk-install__panel", tessFirst && "sk-install__panel--active"]}
      data-install-panel="tessl"
    >
      <code class="sk-install__cmd">{tessInstallCmd}</code>
      <button class="sk-install__copy" type="button" aria-label="Copy install command" data-copy={tessInstallCmd}>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      </button>
    </div>
  )}

  {skillsInstallCmd && (
    <div
      class:list={["sk-install__panel", !tessFirst && "sk-install__panel--active"]}
      data-install-panel="skills"
    >
      <code class="sk-install__cmd">{skillsInstallCmd}</code>
      <button class="sk-install__copy" type="button" aria-label="Copy install command" data-copy={skillsInstallCmd}>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      </button>
    </div>
  )}
</div>

<style>
  .sk-install {
    border: 1px solid var(--tk-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .sk-install__tabs {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid var(--tk-border);
    background: var(--tk-bg-surface);
    padding: 0 0.5rem;
  }

  .sk-install__tab {
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--tk-text-muted);
    cursor: pointer;
    border: none;
    background: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.12s, border-color 0.12s;
  }

  .sk-install__tab:hover {
    color: var(--tk-color-white);
  }

  .sk-install__tab--active {
    color: var(--tk-color-white);
    border-bottom-color: var(--tk-color-accent, #818cf8);
  }

  .sk-install__panel {
    display: none;
    align-items: stretch;
    background: var(--tk-bg-hover);
  }

  .sk-install__panel--active {
    display: flex;
  }

  .sk-install__cmd {
    flex: 1;
    display: block;
    padding: 0.7rem 1rem;
    font-family: var(--tk-font-mono);
    font-size: 0.8rem;
    color: var(--tk-text-muted);
    background: none;
    white-space: nowrap;
    overflow-x: auto;
  }

  .sk-install__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0 0.875rem;
    background: none;
    border: none;
    border-left: 1px solid var(--tk-border);
    color: var(--tk-text-muted);
    cursor: pointer;
    transition: color 0.12s, background 0.12s;
  }

  .sk-install__copy:hover {
    color: var(--tk-color-white);
    background: var(--tk-border);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".sk-install").forEach((block) => {
    block.querySelectorAll<HTMLButtonElement>(".sk-install__tab").forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.installTab;
        block.querySelectorAll<HTMLButtonElement>(".sk-install__tab").forEach((t) => {
          t.classList.toggle("sk-install__tab--active", t === tab);
        });
        block.querySelectorAll<HTMLElement>(".sk-install__panel").forEach((panel) => {
          panel.classList.toggle("sk-install__panel--active", panel.dataset.installPanel === target);
        });
      });
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".sk-install__copy").forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = btn.dataset.copy;
      if (!text) return;
      navigator.clipboard.writeText(text).then(() => {
        const svg = btn.querySelector("svg");
        if (svg) {
          svg.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
          setTimeout(() => {
            svg.innerHTML = '<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>';
          }, 1500);
        }
      });
    });
  });
</script>
