{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prelink": "node -e \"const{symlinkSync,existsSync,unlinkSync}=require('fs');const t='src/content/docs/skills';if(existsSync(t))unlinkSync(t);symlinkSync('../../../../skills',t,'junction');\"",
    "dev": "bun run prelink && astro dev",
    "start": "bun run prelink && astro dev",
    "build": "bun run prelink && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.1",
    "astro": "^6.0.1",
    "gray-matter": "^4.0.3",
    "sharp": "^0.34.2"
  }
}
